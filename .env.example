AWS_REGION=us-east-1

# Named profile from ~/.aws/config (SSO / Identity Center / shared credentials)
# Example: aws sso login --profile my-profile
AWS_PROFILE=your-profile-name

# Amazon Bedrock model (default: amazon.nova-lite-v1:0)
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# Browser → PartyKit host (no protocol). PartyKit dev defaults to localhost:1999
VITE_PARTYKIT_HOST=localhost:1999
